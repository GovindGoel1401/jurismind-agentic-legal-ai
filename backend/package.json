{
  "name": "jurismind-ai-backend",
  "version": "0.1.0",
  "description": "Backend skeleton for JurisMind AI Agentic Legal Verdict Simulator",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:retrieval-routing": "node tests/retrievalRouting.test.js",
    "test:knowledge-graph": "node tests/knowledgeGraph.test.js",
    "test:retrieval-providers": "node tests/retrievalProviders.test.js",
    "test:feedback-memory": "node tests/feedbackMemory.test.js",
    "test:debate-session-continuity": "node tests/debateSessionContinuity.test.js",
    "test:ingestion": "node tests/ingestion.test.js",
